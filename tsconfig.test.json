{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "/tmp/earnest-filter-tests",
    "rootDir": ".",
    "types": ["node"],
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/data/flavors.ts",
    "src/data/flavors.json",
    "src/data/runtime-data.ts",
    "src/data/metadata.json",
    "src/data/stores.ts",
    "src/lib/flavor-browser.ts",
    "src/lib/flavor-logic.ts",
    "tests/*.ts"
  ],
  "exclude": [
    "tests/e2e/**/*"
  ]
}
